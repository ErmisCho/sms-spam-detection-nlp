# Optional Azure OpenAI / Azure AI Foundry embedding provider for semantic clustering.
# Copy these names into your environment; do not commit real secrets.
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-05-01-preview
AZURE_OPENAI_BATCH_SIZE=256
AZURE_OPENAI_CONCURRENCY=4
